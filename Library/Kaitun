Library.SetText = function(name, text, useTween)
    local Label = Library[name]
    if not Label then return end
    if Label.Text == text then return end
    if useTween then
        local TweenService = game:GetService("TweenService")
        local TweenInfoData = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        local FadeOut = TweenService:Create(Label, TweenInfoData, {
            TextTransparency = 1,
            TextStrokeTransparency = 1
        })
        FadeOut:Play()
        FadeOut.Completed:Wait()
        Label.Text = text
        TweenService:Create(Label, TweenInfoData, {
            TextTransparency = 0,
            TextStrokeTransparency = 0
        }):Play()
    else
        Label.Text = text
    end
end

DispTime = function(seconds, fullFormat)
    if fullFormat then
        return string.format("%dday, %dhrs, %dmin, %dsec", math.floor(seconds / 86400), math.floor((seconds % 86400) / 3600), math.floor((seconds % 3600) / 60), seconds % 60)
    else
        if math.floor(seconds / 86400) > 0 then return string.format("%dd %dh %dm %ds", math.floor(seconds / 86400), math.floor((seconds % 86400) / 3600), math.floor((seconds % 3600) / 60), seconds % 60) end
        if math.floor((seconds % 86400) / 3600) > 0 then return string.format("%dh %dm %ds", math.floor((seconds % 86400) / 3600), math.floor((seconds % 3600) / 60), seconds % 60) end
        if math.floor((seconds % 3600) / 60) > 0 then return string.format("%dm %ds", math.floor((seconds % 3600) / 60), seconds % 60) end
        return string.format("%ds", seconds % 60)
    end
end

local ostime = os.time()
local oldostime = isfile('ostime') and tonumber(readfile('ostime')) or 0
task.spawn(function()
    while task.wait(1) do
        local elapsed = os.time() - ostime
        local total = elapsed + oldostime
        Library.SetText('DebugLine', "Total Elapsed Time : " .. DispTime(total, true) .. " Elapsed Time : " .. DispTime(elapsed, true), false)
        writefile('ostime', tostring(total))
    end
end)

return Library
