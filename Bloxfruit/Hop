function Hop()
    local i = game:GetService("ReplicatedStorage"):WaitForChild("__ServerBrowser")
    local j = {}
    for k = 1,100 do
        local l,m = pcall(i.InvokeServer,i,k)
        if l and typeof(m) == "table" then
            for n,o in pairs(m) do
                local p = o.Count or o.Players or 0
                if p < 12 then
                    table.insert(j,n)
                end
            end
        end
        task.wait()
    end
    if #j > 0 then
        i:InvokeServer("teleport",j[math.random(1,#j)])
    end
end
